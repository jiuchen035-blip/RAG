# ==========================================
# Interview RAG Knowledge Base v2 环境配置
# 复制此文件为 .env 并填入实际配置
# ==========================================

# --- 服务基础配置 ---
APP_HOST=127.0.0.1
APP_PORT=8000

# --- PostgreSQL 配置 ---
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=interview_rag

# --- MinIO 对象存储配置 ---
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-files
MINIO_SECURE=false

# --- Milvus 向量库配置 ---
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=interview_chunks

# --- Elasticsearch 配置 ---
ES_HOST=127.0.0.1
ES_PORT=9200

# --- 本地 Embedding / Rerank 模型配置 ---
# 若使用本地模型填写路径，留空则调用API
EMBEDDING_MODEL_PATH=
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
RERANK_MODEL_PATH=

# --- 大模型配置 (OpenAI 兼容格式) ---
# 工具预处理模型 (用于分块/打标签/去重，如 DeepSeek-Flash)
FLASH_API_BASE=https://api.deepseek.com
FLASH_API_KEY=
FLASH_MODEL=deepseek-coder
FLASH_PRICE_PER_1K_INPUT=0.0001
FLASH_PRICE_PER_1K_OUTPUT=0.0002

# 深度问答模型 (用于深度面试问答，如 DeepSeek-Pro)
PRO_API_BASE=https://api.deepseek.com
PRO_API_KEY=
PRO_MODEL=deepseek-chat
PRO_PRICE_PER_1K_INPUT=0.002
PRO_PRICE_PER_1K_OUTPUT=0.004

# --- RAG 全局参数 ---
RAG_TOP_K=5
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_CACHE_ENABLED=true
